{
  "name": "pondorasti",
  "version": "0.1.48",
  "description": "CLI for pondorasti",
  "author": "Alexandru Ţurcanu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pondorasti/pondorasti"
  },
  "main": "src/index.ts",
  "keywords": [
    "cli",
    "macos",
    "homebrew",
    "dotfiles",
    "setup"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pondorasti": "./src/index.ts",
    "pd": "./src/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "prepublishOnly": "bun test",
    "clean": "rm -rf dist .*.bun-build",
    "clean:bun-build": "rm -f .*.bun-build",
    "build": "bun run clean && bun run build:compile && bun run build:sign && bun run clean:bun-build",
    "build:compile": "bun build --compile --minify --outfile=dist/pd src/index.ts",
    "build:sign": "codesign --deep --force --sign - --entitlements entitlements.plist dist/pd"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.35"
  }
}
